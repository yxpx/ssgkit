<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="{{#if page.meta.summary}}{{page.meta.summary}}{{else}}{{site.description}}{{/if}}" />
    <title>{{page.meta.title}} | Project | {{site.title}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Merriweather:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="{{site.assetBase}}favicon.svg" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/typography.css" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/design-system.css" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/components.css" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/layout-project.css" />
    {{#if site.theme}}
      <style>
        :root {
          --accent: {{site.theme.primaryColor}};
          --accent-2: {{site.theme.accentColor}};
        }
      </style>
    {{/if}}
  </head>
  <body>
    <div class="site-wrapper">
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="{{site.assetBase}}index.html" class="{{#if (eq page.slug 'home')}}active{{/if}}">Home</a>
        {{#each site.navItems}}
          <a href="{{../site.assetBase}}{{href}}" class="{{#if (eq ../page.slug slug)}}active{{/if}}">{{title}}</a>
        {{/each}}
      </nav>

      {{> header site=site page=page }}

      <div class="site-body">
        <main class="site-main project-shell" id="main-content">
          <h2 class="section-label publications">{{page.meta.title}}</h2>
          <p class="meta">
            {{#if page.authors}}<span class="pub-authors">{{{formatAuthors page.authors site.title}}}</span>{{/if}}
            {{#if page.venue}}<span class="pub-venue">{{page.venue}}</span>{{/if}}
            {{#if page.year}}<span class="pub-year-badge">{{page.year}}</span>{{/if}}
          </p>

          {{{content}}}

          <p class="back-link"><a href="{{site.assetBase}}index.html">Back to home</a></p>
        </main>

        {{> sidebar site=site }}
      </div>

      {{> footer site=site }}
    </div>
  </body>
</html>
