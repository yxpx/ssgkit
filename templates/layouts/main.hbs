<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="{{site.description}}" />
    <title>{{page.meta.title}} | {{site.title}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Merriweather:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="{{site.assetBase}}favicon.svg" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/typography.css" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/design-system.css" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/components.css" />
    <link rel="stylesheet" href="{{site.assetBase}}styles/layout-main.css" />
    {{#if site.theme}}
      <style>
        :root {
          --accent: {{site.theme.primaryColor}};
          --accent-2: {{site.theme.accentColor}};
        }
      </style>
    {{/if}}
  </head>
  <body>
    <div class="site-wrapper">
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="{{site.assetBase}}index.html" class="{{#if (eq page.slug 'home')}}active{{/if}}">Home</a>
        {{#each site.navItems}}
          <a href="{{../site.assetBase}}{{href}}" class="{{#if (eq ../page.slug slug)}}active{{/if}}">{{title}}</a>
        {{/each}}
      </nav>

      {{> header site=site page=page }}

      <div class="site-body">
        <main class="site-main" id="main-content">
          {{{content}}}

          {{#if site.publicationGroups}}
            <section class="home-publications">
              <h2 class="section-label publications">Publications</h2>
              {{#each site.publicationGroups}}
                <div class="pub-year-group">
                  <div class="pub-year-divider">{{year}}</div>
                  <ul class="pub-list" aria-label="Publication list">
                    {{#each items}}
                      <li class="pub-item">
                        <a class="pub-title" href="{{../../site.assetBase}}projects/{{slug}}.html">{{meta.title}}</a>
                        {{#if authors}}
                          <div class="pub-authors">{{{formatAuthors authors ../../site.title}}}</div>
                        {{/if}}
                        <div class="pub-meta">
                          {{#if venue}}<span class="pub-venue">{{venue}}</span>{{/if}}
                          {{#if year}}<span class="pub-year-badge">{{year}}</span>{{/if}}
                          <span class="pub-type-badge">Paper</span>
                        </div>
                      </li>
                    {{/each}}
                  </ul>
                </div>
              {{/each}}
            </section>
          {{/if}}
        </main>

        {{> sidebar site=site }}
      </div>

      {{> footer site=site }}
    </div>
  </body>
</html>
